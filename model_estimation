library(spdep)

count_data <- readRDS("C:/Users/fabia/OneDrive/Desktop/Master Thesis/R-Stuff/all_counts.rds")
#weights_data <- readRDS("/root/weights_all.rds")
mat <- readRDS("C:/Users/fabia/OneDrive/Desktop/Master Thesis/R-Stuff/big_mat.rds")

mat <- mat[order(rownames(mat)), 
           order(colnames(mat))]


count_data <- count_data %>%
  group_by(region) %>%
  mutate(
    deaths_scaled = as.numeric(scale(deaths))
  ) %>%
  ungroup()


count_data$deaths_scaled_lag <- lag(count_data$deaths_scaled, n = 1)




# Convert adjacency matrix to listw object
W_list <- mat2listw(mat, style = "W")  

count_data$region_fe <- as.factor(count_data$region)
count_data$time_fe   <- as.factor(count_data$years)
count_data$age_fe   <- as.factor(count_data$age)

# Compute the spatial lag of Y
region_year <- count_data %>%
  group_by(region, years) %>%
  summarise(
    Y_prop = sum(Y) / sum(total),
    .groups = "drop"
  )

# compute spatial lag per time period
region_year <- region_year %>%
  group_by(years) %>%
  mutate(
    Y_lag = lag.listw(W_list, Y_prop[order(region)])[order(order(region))]
  ) %>%
  ungroup()

#merge back to original data
count_data <- count_data %>%
  left_join(region_year %>% select(region, years, Y_lag),
            by = c("region", "years"))

count_data <- count_data %>% filter(conflict == 1)

glm_model <- glm(
  cbind(Y, total - Y) ~
    Y_lag + 
    deaths_scaled +
    deaths_scaled_lag +
    hum_scaled_lag +
    strata +
    region_fe +
    time_fe +
    age_fe,
  family = binomial(link = "logit"),
  data   = count_data
)

summary(glm_model)
saveRDS(glm_model, file = "C:/Users/fabia/OneDrive/Desktop/Saved outputs/glm_model_final.rds")
